#!/usr/bin/env bash
# claude-session — list and delete Claude Code session logs
#
# Sessions live under $HOME/.claude/projects/<encoded-cwd>/<uuid>.jsonl
# with an optional sibling <uuid>/ sidecar directory.
set -euo pipefail

ROOT="${CLAUDE_PROJECTS_DIR:-$HOME/.claude/projects}"
HISTORY="$HOME/.claude/history.jsonl"

# Cross-platform file mtime as Unix epoch seconds (formatter handles display).
case "$(uname)" in
  Darwin) file_mtime_epoch() { stat -f '%m' "$1"; } ;;
  *)      file_mtime_epoch() { stat -c '%Y' "$1"; } ;;
esac

# True on Windows-flavored bashes (Git Bash, MSYS2, Cygwin).
is_windows_bash() {
  case "$(uname)" in
    MINGW*|MSYS*|CYGWIN*) return 0 ;;
    *)                    return 1 ;;
  esac
}

# Title cache as parallel indexed arrays. Avoids `declare -gA` (bash 4+),
# so this works on macOS's stock bash 3.2 too.
TITLE_KEYS=()
TITLE_VALS=()
TITLE_TSS=()

# Linear search; echoes index or -1.
_title_idx() {
  local sid="$1" i
  for i in "${!TITLE_KEYS[@]}"; do
    [[ "${TITLE_KEYS[$i]}" == "$sid" ]] && { echo "$i"; return; }
  done
  echo -1
}

# Build sessionId -> earliest-prompt map from ~/.claude/history.jsonl in one
# jq pass. The earliest `.display` per sessionId is what `/resume` shows.
load_history_titles() {
  [[ -f "$HISTORY" ]] || return 0
  local ts sid display idx
  while IFS=$'\t' read -r ts sid display; do
    [[ -z "$sid" || -z "$ts" ]] && continue
    idx=$(_title_idx "$sid")
    if [[ "$idx" == "-1" ]]; then
      TITLE_KEYS+=( "$sid" )
      TITLE_TSS+=( "$ts" )
      TITLE_VALS+=( "$display" )
    elif (( ts < ${TITLE_TSS[$idx]} )); then
      TITLE_TSS[$idx]="$ts"
      TITLE_VALS[$idx]="$display"
    fi
  done < <(jq -r '[.timestamp, .sessionId, .display] | @tsv' "$HISTORY" 2>/dev/null)
}

title_for_session() {
  local idx; idx=$(_title_idx "$1")
  # `|| :` keeps the function's exit code at 0 even when there is no match;
  # otherwise `title=$(title_for_session ...)` propagates the failure and
  # `set -e` aborts the whole list mid-iteration on the first miss.
  [[ "$idx" != "-1" ]] && printf '%s' "${TITLE_VALS[$idx]}" || :
}

usage() {
  cat <<'EOF'
claude-session — manage Claude Code session logs

Usage:
  claude-session list [--here]
  claude-session resume <id> [-- claude-flags...]
  claude-session delete <id> [<id>...] [-f|--force]
  claude-session help

Commands:
  list                  Show all sessions across projects, newest first.
                        --here   only sessions for the current directory.
  resume <id> [args]    Resume a session by UUID or unique prefix (>= 4 chars).
                        Cd's into the session's original project, then execs
                        `claude --resume <uuid> [args]`.
                        With no args and a TTY, prompts:
                          1) default
                          2) dangerously-skip-permissions
                        Any args after <id> are forwarded verbatim to `claude`
                        and bypass the prompt (e.g. --tmux, custom flags).
  delete <id>           Delete by UUID or unique UUID prefix (>= 4 chars).
                        Removes the .jsonl AND its sidecar dir.
                        -f / --force  skip confirmation.
EOF
}

require_jq() {
  command -v jq >/dev/null || { echo "claude-session: needs 'jq' on PATH" >&2; exit 1; }
}

# Locate a working Python 3 interpreter and store the launch command in
# PYTHON3 (may be multiple words, e.g. "py -3"). On Windows, the bare
# `python3` on PATH is often a Microsoft Store redirector that produces no
# output, so probe each candidate with a real import and fall through to
# `py -3` (Python launcher) and `python` if needed.
require_python3() {
  local cand
  for cand in python3 'py -3' python; do
    # shellcheck disable=SC2086
    if $cand -c 'import sys; raise SystemExit(0 if sys.version_info[0]==3 else 1)' \
         </dev/null >/dev/null 2>&1; then
      PYTHON3="$cand"
      return 0
    fi
  done
  echo "claude-session: needs python 3 on PATH (tried: python3, py -3, python)" >&2
  exit 1
}

# Encode a cwd into Claude Code's project-directory name.
#   Linux/macOS:  /home/alice/.claude    -> -home-alice--claude
#   Windows:      C:\Users\alice         -> C--Users-alice
# On Git Bash / MSYS / Cygwin the working directory is reported as
# /c/Users/alice, but Claude Code itself stores the Windows form, so we
# convert before encoding.
encode_path() {
  local p="$1"
  if is_windows_bash; then
    if command -v cygpath >/dev/null 2>&1; then
      p="$(cygpath -m -- "$p")"
    elif [[ "$p" =~ ^/([a-zA-Z])(/.*)?$ ]]; then
      p="${BASH_REMATCH[1]}:${BASH_REMATCH[2]:-/}"
    fi
    p="${p//:/-}"
    p="${p//\\/-}"
  fi
  p="${p//\//-}"
  p="${p//./-}"
  printf '%s' "$p"
}

# Best-effort reverse for display only. The encoder is lossy ('/', '.',
# and on Windows ':' / '\\' all collapse to '-'), so this is a heuristic.
#   Windows form ("<letter>--..." e.g. C--Users-alice) decodes to
#   "C:/Users/alice"; everything else uses the Unix shape.
decode_project() {
  local enc="$1"
  if [[ "$enc" =~ ^([a-zA-Z])--(.*)$ ]]; then
    local drive="${BASH_REMATCH[1]}" rest="${BASH_REMATCH[2]}"
    rest="${rest//-//}"
    printf '%s:/%s' "$drive" "$rest"
    return
  fi
  printf '/%s' "${enc#-}" | tr '-' '/'
}

# Read the session's most recent `/rename` from the JSONL itself.
# /resume shows this when present, so we honor it as the highest-priority title.
# Multiple custom-title records may exist (user renamed more than once); the
# last one wins because that reflects the user's final intent.
custom_title_from_jsonl() {
  local f="$1"
  # The surrounding `tail -n1` picks the LAST such record (latest /rename).
  { jq -r '
      select(.type=="custom-title" and .customTitle!=null) | .customTitle
    ' "$f" 2>/dev/null | tail -n1; } || true
}

# Emit ONE TSV row per session for the python formatter to render:
#   <full_id>\t<mtime_epoch>\t<msgs>\t<project>\t<title>
# Title resolution mirrors Claude Code's `/resume`:
#   1. latest `type:"custom-title"` record in the JSONL (set by `/rename`)
#   2. earliest history.jsonl entry for this sessionId (.display)
#   3. fallback: first last-prompt record in the JSONL (.lastPrompt)
#   4. fallback: "(no prompt)"
format_session_row() {
  local f="$1" full_id mtime msgs project title
  full_id="$(basename "$f" .jsonl)"
  mtime="$(file_mtime_epoch "$f")"
  msgs="$(wc -l < "$f")"
  project="$(decode_project "$(basename "$(dirname "$f")")")"

  title="$(custom_title_from_jsonl "$f")"
  [[ -z "$title" ]] && title="$(title_for_session "$full_id")"
  if [[ -z "$title" ]]; then
    title="$( { jq -r '
        select(.type=="last-prompt" and .lastPrompt!=null) | .lastPrompt
      ' "$f" 2>/dev/null | head -n1; } || true )"
  fi
  [[ -z "$title" ]] && title="(no prompt)"
  # Tabs/newlines would break the TSV line.
  title="$(printf '%s' "$title" | tr '\n\t' '  ')"

  printf '%s\t%s\t%s\t%s\t%s\n' \
    "$full_id" "$mtime" "$msgs" "$project" "$title"
}

# Renderer: reads TSV rows from stdin, prints a styled table.
# Colors emit only when stdout is a TTY (safe to pipe to grep/awk).
#
# We materialize the Python source to a temp file (instead of using process
# substitution `python3 <(...)`) so that native Windows python.exe — which
# can't read the MSYS-virtual /dev/fd/N path that bash's <(...) hands out —
# works alongside Linux/macOS.
format_list() {
  local pyfile rc
  pyfile="$(mktemp)" || { echo "claude-session: mktemp failed" >&2; return 1; }
  cat >"$pyfile" <<'PY'
import sys, os, re, time, datetime, unicodedata, shutil

NOW  = time.time()
TTY  = sys.stdout.isatty()
HOME = os.path.expanduser('~')

# Decorative glyphs fall back to ASCII when stdout isn't UTF-8.
# We can't just try-encode '─' / '…' because Windows code pages like
# cp949 *do* contain mappings for them, but those bytes render as
# mojibake in most consoles. Restricting these glyphs to UTF-8
# sidesteps the problem.
_enc = (sys.stdout.encoding or 'ascii').lower().replace('-', '')
_UNICODE_OK = _enc in ('utf8', 'cp65001')
RULE = '─' if _UNICODE_OK else '-'
ELL  = '…' if _UNICODE_OK else '...'

def cw(c):  return 2 if unicodedata.east_asian_width(c) in ('W','F') else 1
def vlen(s): return sum(cw(c) for c in s)
def vtrunc(s, w):
    out, used = [], 0
    for c in s:
        n = cw(c)
        if used + n > w: break
        out.append(c); used += n
    return ''.join(out), used
def vpad(s, w):
    t, used = vtrunc(s, w)
    return t + ' ' * (w - used)
def vrlefttrunc(s, w):
    if vlen(s) <= w: return ' ' * (w - vlen(s)) + s
    ew = vlen(ELL)
    out, used, target = [], 0, w - ew
    for c in reversed(s):
        n = cw(c)
        if used + n > target: break
        out.append(c); used += n
    return ELL + ''.join(reversed(out)) + ' ' * max(0, w - used - ew)

def reltime(t):
    d = NOW - t
    if d < 0:        return 'future'
    if d < 60:       return 'just now'
    if d < 3600:     return f'{int(d/60)}m ago'
    if d < 86400:    return f'{int(d/3600)}h ago'
    if d < 86400*7:  return f'{int(d/86400)}d ago'
    return datetime.datetime.fromtimestamp(t).strftime('%Y-%m-%d')

def _home_forms():
    # HOME can show up in several spellings depending on which side of
    # the MSYS / native-Windows boundary we got it from:
    #   /c/Users/alice  (Git Bash / MSYS)
    #   C:/Users/alice  (decoded project path)
    #   C:\Users\alice  (native python.exe via os.path.expanduser)
    # Generate every plausible variant so the '~' shortening still
    # matches regardless of which side wins.
    forms = {HOME, HOME.replace('\\', '/')}
    h = HOME.replace('\\', '/')
    m = re.match(r'^/([a-zA-Z])(/.*)?$', h)
    if m:
        d, rest = m.group(1), m.group(2) or ''
        forms.update({d.lower() + ':' + rest, d.upper() + ':' + rest})
    m = re.match(r'^([a-zA-Z]):(/.*)?$', h)
    if m:
        d, rest = m.group(1), m.group(2) or ''
        forms.update({
            '/' + d.lower() + rest,
            d.lower() + ':' + rest,
            d.upper() + ':' + rest,
        })
    return list(forms)

def shorten(p):
    # Encoder collapsed both '/' and '.' to '-', so '//' on decode is most
    # often where a '.' originally lived (e.g. '.claude').
    p = p.replace('//', '/.')
    homes = _home_forms()
    for h in homes:
        if p == h:                  return '~'
        if p.startswith(h + '/'):   return '~' + p[len(h):]
    pl = p.lower()
    for h in homes:
        hl = h.lower()
        if pl == hl:                return '~'
        if pl.startswith(hl + '/'): return '~' + p[len(h):]
    return p

def C(code, s): return f'\033[{code}m{s}\033[0m' if TTY else s
DIM  = lambda s: C('2', s)
BOLD = lambda s: C('1', s)
GRAY = lambda s: C('38;5;245', s)
CYAN = lambda s: C('36', s)

rows = []
for line in sys.stdin:
    parts = line.rstrip('\n').split('\t')
    if len(parts) != 5: continue
    fid, mt, msgs, project, title = parts
    rows.append(dict(
        id=fid[:8],
        mtime=float(mt) if mt else 0.0,
        msgs=msgs,
        project=shorten(project),
        title=title or '(no prompt)',
    ))

if not rows:
    sys.exit(0)

ID_W   = 8
MSGS_W = 5
TIME_W = max(8, max(len(reltime(r['mtime'])) for r in rows))
TERM_W = shutil.get_terminal_size((100, 20)).columns
SEP_W  = 2 * 4  # 4 inter-column gaps of 2 spaces
remaining = max(40, TERM_W - ID_W - TIME_W - MSGS_W - SEP_W)
TITLE_W = max(20, int(remaining * 0.62))
PROJ_W  = max(10, remaining - TITLE_W)

def line(id_s, time_s, title_s, msgs_s, proj_s):
    return f'{id_s}  {time_s}  {title_s}  {msgs_s}  {proj_s}'

# Header
print(BOLD(line(
    vpad('ID',       ID_W),
    vpad('MODIFIED', TIME_W),
    vpad('TITLE',    TITLE_W),
    vpad('MSGS',     MSGS_W),
    vpad('PROJECT',  PROJ_W),
)))
# Rule
print(DIM(line(
    RULE * ID_W,
    RULE * TIME_W,
    RULE * TITLE_W,
    RULE * MSGS_W,
    RULE * PROJ_W,
)))
# Data
for r in rows:
    print(line(
        GRAY(vpad(r['id'], ID_W)),
        DIM(vpad(reltime(r['mtime']), TIME_W)),
        vpad(r['title'], TITLE_W),
        DIM(r['msgs'].rjust(MSGS_W)),
        CYAN(vrlefttrunc(r['project'], PROJ_W)),
    ))
PY
  # shellcheck disable=SC2086
  $PYTHON3 "$pyfile"
  rc=$?
  rm -f -- "$pyfile"
  return $rc
}
# -------------------------------------------------------------------------

cmd_list() {
  local here=0
  case "${1:-}" in
    --here) here=1 ;;
    "") ;;
    *) echo "claude-session list: unknown arg: $1" >&2; return 2 ;;
  esac

  load_history_titles
  shopt -s nullglob
  local files=()
  if (( here )); then
    local enc; enc="$(encode_path "$PWD")"
    files=( "$ROOT/$enc"/*.jsonl )
  else
    files=( "$ROOT"/*/*.jsonl )
  fi
  shopt -u nullglob

  if (( ${#files[@]} == 0 )); then
    echo "(no sessions found)"
    return 0
  fi

  # Gather rows newest-first, render through python.
  while IFS= read -r f; do
    format_session_row "$f"
  done < <(ls -t "${files[@]}") | format_list
}

cmd_delete() {
  local force=0 ids=()
  for arg in "$@"; do
    case "$arg" in
      -f|--force) force=1 ;;
      -*) echo "claude-session: unknown flag: $arg" >&2; return 2 ;;
      *)  ids+=( "$arg" ) ;;
    esac
  done
  (( ${#ids[@]} > 0 )) || { echo "claude-session: delete requires <id>" >&2; return 2; }

  local to_delete=()
  for id in "${ids[@]}"; do
    if (( ${#id} < 4 )); then
      echo "claude-session: id must be >= 4 chars: '$id'" >&2; return 2
    fi
    shopt -s nullglob
    local matches=( "$ROOT"/*/"$id"*.jsonl )
    shopt -u nullglob
    case "${#matches[@]}" in
      0) echo "claude-session: no match for '$id'" >&2; return 1 ;;
      1) to_delete+=( "${matches[0]}" ) ;;
      *) echo "claude-session: '$id' is ambiguous, matches:" >&2
         printf '  %s\n' "${matches[@]}" >&2; return 1 ;;
    esac
  done

  echo "About to delete:"
  for f in "${to_delete[@]}"; do
    local sidecar="${f%.jsonl}"
    printf '  %s\n' "$f"
    [[ -d "$sidecar" ]] && printf '  %s/  (sidecar)\n' "$sidecar"
  done

  if (( ! force )); then
    read -r -p "Proceed? [y/N] " ans </dev/tty
    [[ "$ans" =~ ^[Yy]$ ]] || { echo "aborted."; return 1; }
  fi

  for f in "${to_delete[@]}"; do
    local sidecar="${f%.jsonl}"
    rm -f -- "$f"
    [[ -d "$sidecar" ]] && rm -rf -- "$sidecar"
    echo "deleted $(basename "$f" .jsonl)"
  done
}

# Interactive picker for the resume mode. Echoes the chosen digit on stdout
# (UI goes to stderr so command substitution stays clean). Default is 1.
prompt_resume_mode() {
  local choice
  {
    echo
    echo "Resume mode:"
    echo "  1) default"
    echo "  2) dangerously-skip-permissions"
  } >&2
  read -r -p "Choice [1]: " choice </dev/tty
  printf '%s' "${choice:-1}"
}

cmd_resume() {
  local id="${1:-}"
  [[ -n "$id" ]] || { echo "claude-session: resume requires <id>" >&2; return 2; }
  shift  # remaining "$@" is forwarded verbatim to `claude --resume`
  if (( ${#id} < 4 )); then
    echo "claude-session: id must be >= 4 chars: '$id'" >&2; return 2
  fi

  shopt -s nullglob
  local matches=( "$ROOT"/*/"$id"*.jsonl )
  shopt -u nullglob
  case "${#matches[@]}" in
    0) echo "claude-session: no match for '$id'" >&2; return 1 ;;
    1) ;;
    *) echo "claude-session: '$id' is ambiguous, matches:" >&2
       printf '  %s\n' "${matches[@]}" >&2; return 1 ;;
  esac

  command -v claude >/dev/null \
    || { echo "claude-session: 'claude' CLI not found on PATH" >&2; return 1; }

  local f="${matches[0]}"
  local full_id; full_id="$(basename "$f" .jsonl)"

  # The session's original cwd is stored in the JSONL itself. Decoding the
  # project directory name is lossy ('.' and '/' both collapse to '-'), so we
  # use the in-file `cwd` field as the authoritative source.
  local sess_cwd
  sess_cwd="$( { jq -r 'select(.cwd) | .cwd' "$f" 2>/dev/null | head -n1; } || true )"

  if [[ -n "$sess_cwd" && -d "$sess_cwd" ]]; then
    cd "$sess_cwd" || true
  elif [[ -n "$sess_cwd" ]]; then
    echo "warning: session cwd '$sess_cwd' no longer exists; resuming from $PWD" >&2
  fi

  # If no passthrough flags were given AND we have a TTY, offer the picker.
  # `set --` rewrites positional args so the exec line below stays unchanged
  # whether the flags came from CLI or from the menu.
  if (( $# == 0 )) && [[ -t 0 ]]; then
    case "$(prompt_resume_mode)" in
      1) ;;
      2) set -- --dangerously-skip-permissions ;;
      *) echo "claude-session: invalid resume-mode choice" >&2; return 2 ;;
    esac
  fi

  # Hand control to claude; this process is replaced.
  exec claude --resume "$full_id" "$@"
}

main() {
  require_jq
  require_python3
  local sub="${1:-help}"; shift || true
  case "$sub" in
    list)            cmd_list   "$@" ;;
    delete)          cmd_delete "$@" ;;
    resume)          cmd_resume "$@" ;;
    help|-h|--help|"") usage ;;
    *) echo "claude-session: unknown command: $sub" >&2; usage; return 2 ;;
  esac
}
main "$@"
